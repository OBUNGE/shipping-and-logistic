    <style>

    </style>
  </head>

  <body>
    <header>
      <%= render "layouts/navbar" %>
    </header>

    <%# --- Flash Messages --- %>
    <div id="flash-messages" class="container-fluid px-3 pt-2">
      <% flash.each do |key, value| %>
        <div class="alert alert-<%= key == "notice" ? "success" : "danger" %> alert-dismissible fade show shadow-sm" role="alert">
          <%= value %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <%# --- Main Content --- %>
    <main class="container-fluid px-0" role="main">
      <%= yield %>
    </main>

    <%# --- Footer --- %>
    <footer class="bg-dark text-light py-5 mt-5 border-top border-secondary" style="background: linear-gradient(135deg, #6F370F 0%, #8B4513 100%) !important;">
      <div class="container">
        <div class="row g-4 mb-4">
          <!-- About Section -->
          <div class="col-md-4 mb-3 mb-md-0">
            <h6 class="fw-bold mb-3 text-warning" style="color: #DEB887 !important;">
              <i class="bi bi-shop me-2"></i>Tajaone
            </h6>
            <p class="small text-muted mb-3">
              Kenya's trusted online store for high-quality, affordable leather products. Handcrafted with pride in Nairobi.
            </p>
            <div class="d-flex gap-2">
              <a href="https://facebook.com" class="btn btn-sm btn-outline-light rounded-circle p-2 hover-lift" title="Facebook">
                <i class="bi bi-facebook"></i>
              </a>
              <a href="https://twitter.com" class="btn btn-sm btn-outline-light rounded-circle p-2 hover-lift" title="Twitter">
                <i class="bi bi-twitter"></i>
              </a>
              <a href="https://instagram.com" class="btn btn-sm btn-outline-light rounded-circle p-2 hover-lift" title="Instagram">
                <i class="bi bi-instagram"></i>
              </a>
              <a href="https://whatsapp.com" class="btn btn-sm btn-outline-light rounded-circle p-2 hover-lift" title="WhatsApp">
                <i class="bi bi-whatsapp"></i>
              </a>
            </div>
          </div>

          <!-- Quick Links -->
          <div class="col-md-2 col-6">
            <h6 class="fw-bold mb-3" style="color: #DEB887;">Quick Links</h6>
            <ul class="list-unstyled small">
              <li class="mb-2">
                <%= link_to "Home", root_path, class: "text-muted text-decoration-none hover-text-light" %>
              </li>
              <li class="mb-2">
                <%= link_to "Products", products_path, class: "text-muted text-decoration-none hover-text-light" %>
              </li>
              <li class="mb-2">
                <%= link_to "About Us", about_path, class: "text-muted text-decoration-none hover-text-light" %>
              </li>
              <li class="mb-2">
                <%= link_to "Contact", contact_path, class: "text-muted text-decoration-none hover-text-light" %>
              </li>
            </ul>
          </div>

          <!-- Policies -->
          <div class="col-md-2 col-6">
            <h6 class="fw-bold mb-3" style="color: #DEB887;">Policies</h6>
            <ul class="list-unstyled small">
              <li class="mb-2">
                <%= link_to "Return Policy", return_policy_path, class: "text-muted text-decoration-none hover-text-light" %>
              </li>
              <li class="mb-2">
                <a href="#" class="text-muted text-decoration-none hover-text-light">Privacy Policy</a>
              </li>
              <li class="mb-2">
                <a href="#" class="text-muted text-decoration-none hover-text-light">Terms & Conditions</a>
              </li>
              <li class="mb-2">
                <a href="#" class="text-muted text-decoration-none hover-text-light">Shipping Info</a>
              </li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div class="col-md-4">
            <h6 class="fw-bold mb-3" style="color: #DEB887;">Contact Us</h6>
            <ul class="list-unstyled small">
              <li class="mb-2">
                <i class="bi bi-envelope me-2" style="color: #DEB887;"></i>
                <a href="mailto:sales@tajaone.app" class="text-muted text-decoration-none hover-text-light">
                  sales@tajaone.app
                </a>
              </li>
              <li class="mb-2">
                <i class="bi bi-telephone me-2" style="color: #DEB887;"></i>
                <a href="tel:+254726565342" class="text-muted text-decoration-none hover-text-light">
                  +254 726 565 342
                </a>
              </li>
              <li class="mb-2">
                <i class="bi bi-geo-alt me-2" style="color: #DEB887;"></i>
                <span class="text-muted">Nairobi, Kenya</span>
              </li>
              <li class="mb-2">
                <i class="bi bi-clock me-2" style="color: #DEB887;"></i>
                <span class="text-muted">Mon - Fri: 9AM - 6PM</span>
              </li>
            </ul>
          </div>
        </div>

        <hr class="border-secondary opacity-25 my-4">

        <!-- Bottom Footer -->
        <div class="row align-items-center">
          <div class="col-md-6 text-center text-md-start">
            <p class="mb-0 small text-muted">
              &copy; <%= Time.current.year %> <span class="fw-bold" style="color: #DEB887;">Tajaone</span> — Kenya's Source for Affordable Leather Products.
            </p>
          </div>
          <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
            <div class="d-flex gap-2 justify-content-center justify-content-md-end flex-wrap">
              <img src="https://img.shields.io/badge/M--PESA-Accepted-blue" alt="M-PESA" class="img-fluid" style="height: 20px;">
              <img src="https://img.shields.io/badge/PayPal-Accepted-009cde" alt="PayPal" class="img-fluid" style="height: 20px;">
              <img src="https://img.shields.io/badge/Secure-SSL-green" alt="SSL" class="img-fluid" style="height: 20px;">
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>