<div style="padding-bottom: 6rem;">
  <!-- Header -->
  <div class="bg-white border-bottom border-dark p-4 sticky-top" style="top: 5rem; z-index: 40;">
    <h2 class="fs-5 fw-bold">Shopping Cart</h2>
  </div>

  <!-- Cart Items -->
  <div class="p-4">
    <% if @cart_items.any? %>
      <div class="d-flex flex-column gap-3 mb-4">
        <% @cart_items.each do |product_id, quantity| %>
          <% product = @products[product_id.to_i] %>
          <% next unless product %>
          <div class="d-flex gap-3 p-3 border border-dark rounded bg-white">
            <!-- Item Image -->
            <div class="flex-shrink-0 bg-light border border-dark rounded d-flex align-items-center justify-content-center overflow-hidden" style="width: 80px; height: 80px;">
              <% if product.image_url.present? %>
                <%= image_tag product.image_url, class: "w-100 h-100", style: "object-fit: cover;" %>
              <% else %>
                <span class="fs-4">📷</span>
              <% end %>
            </div>
            
            <!-- Item Details -->
            <div class="flex-grow-1">
              <h3 class="fw-bold fs-7 mb-2"><%= product.title %></h3>
              <p class="fs-7 text-secondary mb-2">Quantity: <%= quantity %></p>
              
              <div class="d-flex align-items-center justify-content-between">
                <span class="fw-bold text-primary">KES <%= number_with_precision(product.price * quantity, precision: 2) %></span>
                
                <form action="<%= mobile_cart_remove_item_path %>" method="post" class="d-inline">
                  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                  <%= hidden_field_tag :_method, :delete %>
                  <%= hidden_field_tag :product_id, product_id %>
                  <button type="submit" class="btn btn-link text-danger p-0">
                    ✕
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Cart Summary -->
      <% total = @cart_items.sum { |pid, qty| @products[pid.to_i]&.price.to_i * qty } %>
      <div class="bg-light border border-dark p-4 rounded mb-4">
        <div class="d-flex flex-column gap-2 mb-4 pb-4 border-bottom border-dark">
          <div class="d-flex justify-content-between fs-7">
            <span>Subtotal</span>
            <span>KES <%= number_with_precision(total || 0, precision: 2) %></span>
          </div>
          <div class="d-flex justify-content-between fs-7">
            <span>Shipping</span>
            <span class="text-success fw-bold">FREE</span>
          </div>
          <div class="d-flex justify-content-between fs-7">
            <span>Tax (16%)</span>
            <span>KES <%= number_with_precision((total || 0) * 0.16, precision: 2) %></span>
          </div>
        </div>
        
        <div class="d-flex justify-content-between fs-5 fw-bold">
          <span>Total</span>
          <span class="text-primary">KES <%= number_with_precision((total || 0) * 1.16, precision: 2) %></span>
        </div>
      </div>

      <!-- Checkout Button -->
      <% if user_signed_in? %>
        <a href="<%= new_mobile_order_path %>" class="btn btn-dark w-100 py-3 fw-bold text-center mb-3">
          Proceed to Checkout
        </a>
      <% else %>
        <a href="<%= new_user_session_path %>" class="btn btn-dark w-100 py-3 fw-bold text-center mb-3">
          Sign In to Checkout
        </a>
      <% end %>

      <!-- Continue Shopping -->
      <a href="<%= mobile_products_path %>" class="btn btn-outline-dark w-100 py-3 fw-bold text-center">
        Continue Shopping
      </a>

    <% else %>
      <!-- Empty Cart -->
      <div class="text-center py-5">
        <div class="fs-1 mb-4">🛒</div>
        <p class="fs-5 fw-bold mb-2">Your cart is empty</p>
        <p class="text-secondary fs-7 mb-4">Add some items to get started</p>
        <a href="<%= mobile_products_path %>" class="btn btn-dark px-4 py-3 fw-bold">
          Start Shopping
        </a>
      </div>
    <% end %>
  </div>
</div>
