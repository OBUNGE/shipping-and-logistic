<div style="padding-bottom: 5rem;">
  <!-- Product Gallery -->
  <div class="position-relative bg-light border-bottom border-dark" style="height: 24rem;">
    <% if @product.image_url.present? %>
      <%= image_tag @product.image_url, style: "width: 100%; height: 100%; object-fit: cover;" %>
    <% else %>
      <div class="w-100 h-100 d-flex align-items-center justify-content-center">
        <span class="fs-1">📷</span>
      </div>
    <% end %>
    
    <a href="<%= mobile_products_path %>" class="position-absolute top-0 start-0 m-2 btn btn-dark btn-sm p-2">
      ←
    </a>
  </div>

  <!-- Product Info -->
  <div class="p-4">
    <!-- Title and Rating -->
    <h1 class="fs-4 fw-bold mb-2"><%= @product.title %></h1>
    
    <div class="d-flex align-items-center gap-2 mb-3">
      <div class="d-flex gap-1">
        <% 5.times do |i| %>
          <span class="fs-5"><%= i < 4 ? '⭐' : '☆' %></span>
        <% end %>
      </div>
      <span class="fs-7 text-secondary">(<%= @reviews.count %> reviews)</span>
    </div>

    <!-- Price -->
    <div class="mb-4 pb-4 border-bottom border-dark">
      <% if @product.discount&.active? %>
        <div class="fs-2 fw-bold text-primary mb-2">
          KES <%= number_with_precision(@product.discounted_price, precision: 2) %>
        </div>
        <div class="fs-7 text-secondary text-decoration-line-through">
          KES <%= number_with_precision(@product.original_price, precision: 2) %>
        </div>
        <div class="fs-7 text-success fw-bold">
          Save <%= number_with_precision(@product.original_price - @product.discounted_price, precision: 2) %>
        </div>
      <% else %>
        <div class="fs-2 fw-bold text-primary mb-2">
          KES <%= number_with_precision(@product.price, precision: 2) %>
        </div>
      <% end %>
    </div>

    <!-- Availability -->
    <div class="mb-4">
      <p class="fs-7 fw-bold mb-2">Availability</p>
      <div class="d-flex gap-2">
        <span class="badge bg-success">In Stock</span>
        <span class="text-secondary fs-7 py-2">Fast Delivery Available</span>
      </div>
    </div>

    <!-- Description -->
    <div class="mb-4 pb-4 border-bottom border-dark">
      <p class="fs-7 fw-bold mb-2">Description</p>
      <p class="text-secondary fs-6 lh-lg"><%= @product.description.to_plain_text %></p>
    </div>

    <!-- Quantity Selector -->
    <div class="mb-4 pb-4 border-bottom border-dark">
      <p class="fs-7 fw-bold mb-3">Quantity</p>
      <div class="d-flex align-items-center gap-3">
        <button type="button" class="btn btn-outline-dark p-2" style="width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;">−</button>
        <input type="number" value="1" min="1" class="form-control text-center" style="width: 48px;" readonly>
        <button type="button" class="btn btn-outline-dark p-2" style="width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;">+</button>
      </div>
    </div>

    <!-- Add to Cart Button -->
    <form action="<%= mobile_cart_add_item_path %>" method="post" class="mb-4">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <%= hidden_field_tag :product_id, @product.id %>
      <button type="submit" class="btn btn-dark w-100 py-3 fw-bold fs-5">
        Add to Cart - KES <%= number_with_precision(@product.price, precision: 2) %>
      </button>
    </form>

    <!-- Seller Info -->
    <div class="p-4 bg-info bg-opacity-10 border border-info rounded mb-4">
      <p class="fs-7 fw-bold text-info mb-2">🏪 Sold by</p>
      <p class="fw-bold mb-2"><%= @product.seller&.name || 'Taja Shop' %></p>
      <p class="fs-7 text-info">Trusted seller • Fast shipping</p>
    </div>

    <!-- Write Review Button -->
    <button type="button" class="btn btn-outline-dark w-100 fw-bold">
      Write a Review
    </button>
  </div>
</div>
