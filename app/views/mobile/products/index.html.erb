<div style="padding-bottom: 5rem;">
  <!-- Header -->
  <div class="bg-white border-bottom border-dark p-4 sticky-top" style="top: 56px; z-index: 999;">
    <h2 class="fs-5 fw-bold mb-3">All Products</h2>
    
    <!-- Filters -->
    <div class="d-flex gap-2 overflow-auto pb-2" style="overflow-x: auto;">
      <a href="<%= mobile_products_path %>" class="text-decoration-none btn btn-sm" style="<%= 'background-color: #212529; color: white;' if params[:category_id].blank? %> border: 2px solid #212529;">
        All
      </a>
      <% @categories.each do |category| %>
        <a href="<%= mobile_products_path(category_id: category.id) %>" class="text-decoration-none btn btn-sm" style="<%= 'background-color: #212529; color: white;' if params[:category_id].to_i == category.id %> border: 2px solid #212529;">
          <%= category.name %>
        </a>
      <% end %>
    </div>
  </div>

  <!-- Products Grid -->
  <div class="p-4">
    <% if @products.any? %>
      <div class="d-flex flex-column gap-3">
        <% @products.each do |product| %>
          <a href="<%= mobile_product_path(product) %>" class="text-decoration-none text-dark d-flex gap-3 p-3 border border-dark rounded bg-white" style="transition: box-shadow 0.2s;">
            <!-- Product Image -->
            <div class="flex-shrink-0" style="width: 96px; height: 96px; background-color: #e9ecef; border: 2px solid #212529; border-radius: 0.375rem; display: flex; align-items: center; justify-content: center; overflow: hidden;">
              <% if product.image_url.present? %>
                <%= image_tag product.image_url, style: "width: 100%; height: 100%; object-fit: cover;" %>
              <% else %>
                <span class="fs-3">📷</span>
              <% end %>
            </div>
            
            <!-- Product Details -->
            <div class="flex-grow-1 d-flex flex-column">
              <h3 class="fw-bold fs-6 mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= product.title %></h3>
              <p class="fs-7 text-secondary mb-2" style="display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;"><%= truncate(product.description.to_plain_text, length: 50) %></p>
              
              <div class="mt-auto d-flex justify-content-between align-items-center">
                <div>
                  <span class="fw-bold text-primary fs-5">KES <%= number_with_precision(product.price, precision: 2) %></span>
                </div>
                <span class="fs-7 bg-success bg-opacity-25 text-success px-2 py-1 rounded">Stock</span>
              </div>
            </div>
          </a>
        <% end %>
      </div>

      <!-- Pagination -->
      <% if @products.respond_to?(:total_pages) %>
        <div class="mt-5 d-flex gap-2 justify-content-center">
          <% (1..@products.total_pages).each do |page| %>
            <% if page == @products.current_page %>
              <span class="btn btn-sm btn-dark fw-bold"><%= page %></span>
            <% else %>
              <a href="<%= mobile_products_path(page: page, category_id: params[:category_id]) %>" class="btn btn-sm btn-outline-dark"><%= page %></a>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-5">
        <p class="text-secondary fs-5 mb-4">No products found</p>
        <a href="<%= mobile_home_index_path %>" class="text-primary fw-bold text-decoration-none">Back to Home</a>
      </div>
    <% end %>
  </div>
</div>
