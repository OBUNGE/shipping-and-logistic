<div style="padding-bottom: 5rem;">
  <!-- Header -->
  <div class="bg-white border-bottom border-dark p-4 sticky-top" style="top: 5rem; z-index: 40;">
    <h2 class="fs-5 fw-bold">Checkout</h2>
  </div>

  <div class="p-4">
    <!-- Order Summary -->
    <div class="bg-info bg-opacity-10 border border-info p-4 rounded mb-4">
      <h3 class="fw-bold mb-3">Order Summary</h3>
      <% total_amount = 0 %>
      <div class="d-flex flex-column gap-2 fs-7 mb-3 pb-3 border-bottom border-info">
        <% @products.each do |product| %>
          <% qty = @cart_items[product.id.to_s].to_i %>
          <% item_total = product.price * qty %>
          <% total_amount += item_total %>
          <div class="d-flex justify-content-between">
            <span><%= product.title %> × <%= qty %></span>
            <span>KES <%= number_with_precision(item_total, precision: 2) %></span>
          </div>
        <% end %>
      </div>
      <% total_with_tax = total_amount * 1.16 %>
      <div class="d-flex justify-content-between fw-bold">
        <span>Total Amount</span>
        <span class="text-primary fs-5">KES <%= number_with_precision(total_with_tax, precision: 2) %></span>
      </div>
    </div>

    <!-- Checkout Form -->
    <form action="<%= mobile_orders_path %>" method="post" class="d-flex flex-column gap-4">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <!-- Contact Information -->
      <div class="pb-4 border-bottom border-dark">
        <h3 class="fw-bold mb-3">Contact Information</h3>
        
        <div class="mb-3">
          <label class="form-label fw-semibold">Email Address</label>
          <input type="email" name="order[email]" value="<%= current_user&.email %>" required class="form-control border border-dark">
        </div>

        <div>
          <label class="form-label fw-semibold">Phone Number</label>
          <input type="tel" name="order[phone]" placeholder="+254 712 345 678" required class="form-control border border-dark">
        </div>
      </div>

      <!-- Shipping Address -->
      <div class="pb-4 border-bottom border-dark">
        <h3 class="fw-bold mb-3">Shipping Address</h3>
        
        <div class="mb-3">
          <label class="form-label fw-semibold">Street Address</label>
          <input type="text" name="order[address]" placeholder="Enter your address" required class="form-control border border-dark">
        </div>

        <div class="row g-3 mb-3">
          <div class="col-6">
            <label class="form-label fw-semibold">City</label>
            <input type="text" name="order[city]" placeholder="Nairobi" required class="form-control border border-dark">
          </div>

          <div class="col-6">
            <label class="form-label fw-semibold">Postal Code</label>
            <input type="text" name="order[zip_code]" placeholder="00100" required class="form-control border border-dark">
          </div>
        </div>
      </div>

      <!-- Payment Method -->
      <div class="pb-4 border-bottom border-dark">
        <h3 class="fw-bold mb-3">Payment Method</h3>
        
        <label class="d-flex align-items-center p-3 border border-dark rounded mb-3" style="cursor: pointer;">
          <input type="radio" name="order[payment_method]" value="mpesa" checked class="form-check-input me-3">
          <span class="fw-semibold">M-Pesa</span>
        </label>

        <label class="d-flex align-items-center p-3 border border-dark rounded mb-3" style="cursor: pointer;">
          <input type="radio" name="order[payment_method]" value="card" class="form-check-input me-3">
          <span class="fw-semibold">Credit/Debit Card</span>
        </label>

        <label class="d-flex align-items-center p-3 border border-dark rounded" style="cursor: pointer;">
          <input type="radio" name="order[payment_method]" value="bank_transfer" class="form-check-input me-3">
          <span class="fw-semibold">Bank Transfer</span>
        </label>
      </div>

      <!-- Terms Agreement -->
      <label class="d-flex gap-3 p-3 border border-warning bg-warning bg-opacity-10 rounded">
        <input type="checkbox" required class="form-check-input mt-1">
        <span class="fs-7">I agree to the terms and conditions and privacy policy</span>
      </label>

      <!-- Submit Button -->
      <button type="submit" class="btn btn-dark w-100 py-3 fw-bold fs-5">
        Place Order
      </button>

      <!-- Back Button -->
      <a href="<%= mobile_cart_path %>" class="btn btn-outline-dark w-100 py-3 fw-bold text-center">
        Back to Cart
      </a>
    </form>
  </div>
</div>
