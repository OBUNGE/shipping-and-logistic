<div style="padding-bottom: 5rem;">
  <!-- Hero Banner -->
  <div class="bg-primary text-white p-5 text-center">
    <div class="mb-4">
      <svg class="mx-auto" width="64" height="64" viewBox="0 0 200 200" fill="currentColor">
        <path d="M 30 80 L 100 50 L 170 80 L 170 150 Q 170 170 150 170 L 50 170 Q 30 170 30 150 Z" />
      </svg>
    </div>
    <h2 class="fs-4 fw-bold mb-3">Welcome to Taja Shop</h2>
    <p class="fs-6 mb-4">Authentic African-crafted goods delivered to your door</p>
    <a href="<%= mobile_products_path %>" class="btn btn-light fw-bold">
      Shop Now →
    </a>
  </div>

  <!-- Featured Categories -->
  <div class="p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="fs-5 fw-bold">Shop by Category</h3>
      <a href="<%= mobile_product_categories_path %>" class="text-primary fs-6 fw-bold" style="text-decoration: none;">View All</a>
    </div>

    <div class="row g-3">
      <% @categories.each do |category| %>
        <div class="col-6">
          <a href="<%= mobile_products_path(category_id: category.id) %>" class="text-decoration-none text-dark d-block border border-dark rounded overflow-hidden" style="transition: box-shadow 0.2s;">
            <div class="bg-light p-5 text-center border-bottom border-dark">
              <div class="fs-1 text-secondary">📦</div>
            </div>
            <div class="p-3">
              <h4 class="fw-bold fs-6 mb-2"><%= category.name %></h4>
              <p class="fs-7 text-secondary"><%= category.products.count %> items</p>
            </div>
          </a>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Featured Products -->
  <div class="p-4 border-top border-dark">
    <h3 class="fs-5 fw-bold mb-4">Featured Products</h3>
    
    <div class="d-flex flex-column gap-3">
      <% @featured_products.each do |product| %>
        <a href="<%= mobile_product_path(product) %>" class="text-decoration-none text-dark d-flex gap-3 p-3 border border-dark rounded" style="transition: box-shadow 0.2s;">
          <!-- Product Image Placeholder -->
          <div class="flex-shrink-0" style="width: 80px; height: 80px; background-color: #e9ecef; border: 2px solid #212529; border-radius: 0.375rem; display: flex; align-items: center; justify-content: center;">
            <% if product.image_url.present? %>
              <%= image_tag product.image_url, style: "width: 100%; height: 100%; object-fit: cover; border-radius: 0.25rem;" %>
            <% else %>
              <span class="fs-4">📷</span>
            <% end %>
          </div>
          
          <!-- Product Info -->
          <div class="flex-grow-1">
            <h4 class="fw-bold fs-6 mb-2"><%= product.title %></h4>
            <p class="fs-7 text-secondary mb-2">
              <%= truncate(product.description.to_plain_text, length: 50) %>
            </p>
            <div class="d-flex justify-content-between align-items-center">
              <span class="fw-bold fs-5 text-primary">KES <%= number_with_precision(product.price, precision: 2) %></span>
              <span class="fs-7 bg-success bg-opacity-25 text-success px-2 py-1 rounded">In Stock</span>
            </div>
          </div>
        </a>
      <% end %>
    </div>

    <a href="<%= mobile_products_path %>" class="btn btn-dark w-100 fw-bold mt-4">
      View All Products
    </a>
  </div>

  <!-- Why Taja -->
  <div class="p-4 bg-warning bg-opacity-10 border-top border-dark">
    <h3 class="fw-bold mb-3">Why Taja Shop?</h3>
    <ul class="list-unstyled fs-6 d-flex flex-column gap-2">
      <li class="d-flex gap-2">
        <span>✓</span>
        <span>Authentic African craftsmanship</span>
      </li>
      <li class="d-flex gap-2">
        <span>✓</span>
        <span>Fast delivery across Kenya</span>
      </li>
      <li class="d-flex gap-2">
        <span>✓</span>
        <span>Secure payment options</span>
      </li>
      <li class="d-flex gap-2">
        <span>✓</span>
        <span>Money-back guarantee</span>
      </li>
    </ul>
  </div>
</div>
